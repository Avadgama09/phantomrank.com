---
import Layout from "../layouts/Layout.astro";
import { pageMeta, stats } from "../utils/data";

const meta = pageMeta.signup;
---

<Layout
  title={meta.title}
  description={meta.description}
  breadcrumbs={[
    { name: "Home", href: "/" },
    { name: "Get Access", href: "/signup" },
  ]}
>
  <section class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-start">
      {/* ── Left Column: Copy ── */}
      <div class="reveal">
        <div
          class="inline-flex items-center gap-2 px-3 py-1 text-primary text-lg font-semibold mb-4"
        >
          Get Access
        </div>
        <h1
          class="text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4"
        >
          Start tracking your brand's
          <span
            class="bg-linear-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent"
          >
            AI visibility
          </span>
        </h1>
        <p class="text-lg text-muted-foreground mb-8">
          Create your free account and see how your brand shows up across
          ChatGPT, Perplexity, Gemini, Claude, Grok, and Copilot. No credit
          card required.
        </p>

        <div class="space-y-4 mb-8">
          {[
            "Free plan — 1 brand, 5 scans/month, 1 competitor",
            "Live dashboard with brand mentions and citations",
            "Results in minutes, not days",
            "Upgrade or cancel anytime",
          ].map((item) => (
            <div class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-green-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.5 12.75l6 6 9-13.5"
                />
              </svg>
              <span class="text-muted-foreground">{item}</span>
            </div>
          ))}
        </div>

        <div class="grid grid-cols-2 gap-4">
          {stats.slice(0, 2).map((stat) => (
            <div class="rounded-xl border border-border bg-card p-4 text-center">
              <p class="text-2xl font-bold text-foreground">{stat.value}</p>
              <p class="text-xs text-muted-foreground">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>

      {/* ── Right Column: Form ── */}
      <div class="reveal">
        <div class="bg-card rounded-2xl border border-border p-8 shadow-sm">
          <h2 class="text-xl font-semibold text-foreground mb-6">
            Create your account
          </h2>

          <form class="space-y-5" action="/signup" method="POST">
            <div>
              <label
                for="name"
                class="block text-sm font-medium text-foreground mb-1.5"
              >
                Full name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Ashish Vadgama"
                class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all"
              />
            </div>

            <div>
              <label
                for="email"
                class="block text-sm font-medium text-foreground mb-1.5"
              >
                Work email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="you@agency.com"
                class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all"
              />
            </div>

            <div>
              <label
                for="agency"
                class="block text-sm font-medium text-foreground mb-1.5"
              >
                Agency / Company name
              </label>
              <input
                type="text"
                id="agency"
                name="agency"
                placeholder="Acme Digital"
                class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all"
              />
            </div>

            <div>
              <label
                for="brands"
                class="block text-sm font-medium text-foreground mb-1.5"
              >
                How many brands do you manage?
              </label>
              <select
                id="brands"
                name="brands"
                class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all"
              >
                <option value="">Select</option>
                <option value="1-3">1–3 brands</option>
                <option value="4-10">4–10 brands</option>
                <option value="11-25">11–25 brands</option>
                <option value="25+">25+ brands</option>
              </select>
            </div>

            <button
              type="submit"
              class="w-full rounded-full bg-primary px-8 py-3.5 text-sm font-semibold text-white transition-all hover:bg-primary/80 hover:shadow-lg hover:shadow-primary/25"
            >
              Get Access — It's Free
            </button>
          </form>

          <p class="mt-4 text-center text-xs text-muted-foreground">
            By signing up you agree to our
            <a href="/terms" class="text-primary hover:text-primary/80">Terms</a>
            and
            <a href="/privacy" class="text-primary hover:text-primary/80">Privacy Policy</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
