---
import Layout from "../layouts/Layout.astro";
import { pageMeta, stats } from "../utils/data";

const meta = pageMeta.signup;
---

<Layout
  title={meta.title}
  description={meta.description}
  breadcrumbs={[
    { name: "Home", href: "/" },
    { name: "Get Access", href: "/signup" },
  ]}
>
  <section class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-start">
      {/* ── Left Column: Copy ── */}
      <div class="reveal">
        <div
          class="inline-flex items-center gap-2 px-3 py-1 text-primary text-lg font-semibold mb-4"
        >
          Get Access
        </div>
        <h1
          class="text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4"
        >
          Let's get your agency
          <span
            class="bg-linear-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent"
          >
            AI-search ready
          </span>
        </h1>
        <p class="text-lg text-muted-foreground mb-8">
          Tell us a little about your agency and we'll get you set up. Whether
          you're managing 3 brands or 300, we'll find the right plan for you.
        </p>

        <div class="space-y-4 mb-8">
          {[
            "Free plan available — no credit card required",
            "Track brands across ChatGPT, Perplexity, Gemini, Claude, Grok & Copilot",
            "Live dashboard with mentions, citations, and share of voice",
            "Setup in minutes — first results the same day",
            "Upgrade, downgrade, or cancel anytime",
          ].map((item) => (
            <div class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-green-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.5 12.75l6 6 9-13.5"
                />
              </svg>
              <span class="text-muted-foreground">{item}</span>
            </div>
          ))}
        </div>

        <div class="grid grid-cols-2 gap-4">
          {stats.slice(0, 2).map((stat) => (
            <div class="rounded-xl border border-border bg-card p-4 text-center">
              <p class="text-2xl font-bold text-foreground">{stat.value}</p>
              <p class="text-xs text-muted-foreground">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>

      {/* ── Right Column: Form ── */}
      <div class="reveal">
        <div class="bg-card rounded-2xl border border-border p-8 shadow-sm">
          <h2 class="text-xl font-semibold text-foreground mb-6">
            Request access
          </h2>

          <form id="signup-form" class="space-y-5">
            <div>
              <label
                for="name"
                class="block text-sm font-medium text-foreground mb-1.5"
              >
                Full name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="First & Last Name"
                class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all"
              />
            </div>

            <div>
              <label
                for="email"
                class="block text-sm font-medium text-foreground mb-1.5"
              >
                Work email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="you@agency.com"
                class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all"
              />
            </div>

            <div>
              <label
                for="agency"
                class="block text-sm font-medium text-foreground mb-1.5"
              >
                Agency / Company name
              </label>
              <input
                type="text"
                id="agency"
                name="agency"
                placeholder="Digital Agency Inc."
                class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all"
              />
            </div>

            <div>
              <label
                for="brands"
                class="block text-sm font-medium text-foreground mb-1.5"
              >
                How many brands do you manage?
              </label>
              <select
                id="brands"
                name="brands"
                class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all"
              >
                <option value="">Select</option>
                <option value="1-3">1–3 brands</option>
                <option value="4-10">4–10 brands</option>
                <option value="11-25">11–25 brands</option>
                <option value="25+">25+ brands</option>
              </select>
            </div>

            <div>
              <label
                for="message"
                class="block text-sm font-medium text-foreground mb-1.5"
              >
                How can we help? <span class="text-muted-foreground font-normal">(optional)</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                placeholder="Tell us about your agency, the clients you work with, or anything you'd like us to know before we get in touch."
                class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              id="signup-btn"
              class="w-full rounded-full bg-primary px-8 py-3.5 text-sm font-semibold text-white transition-all hover:bg-primary/80 hover:shadow-lg hover:shadow-primary/25"
            >
              Request Access
            </button>
          </form>

          <div id="signup-success" class="hidden py-12 text-center">
            <svg class="mx-auto h-12 w-12 text-green-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="text-lg font-semibold text-foreground mb-2">You're on the list!</h3>
            <p class="text-sm text-muted-foreground">We'll be in touch within 24 hours to get you set up.</p>
          </div>

          <div id="signup-error" class="hidden mt-4 rounded-xl bg-red-500/10 border border-red-500/20 p-4 text-center">
            <p class="text-sm text-red-400">Something went wrong. Please try again or email us directly.</p>
          </div>

          <p class="mt-4 text-center text-xs text-muted-foreground">
            By submitting this form you agree to our
            <a href="/terms" class="text-primary hover:text-primary/80">Terms</a>
            and
            <a href="/privacy" class="text-primary hover:text-primary/80">Privacy Policy</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById("signup-form") as HTMLFormElement;
  const btn = document.getElementById("signup-btn") as HTMLButtonElement;
  const successEl = document.getElementById("signup-success")!;
  const errorEl = document.getElementById("signup-error")!;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = "Submitting…";
    errorEl.classList.add("hidden");

    const payload = {
      name: (document.getElementById("name") as HTMLInputElement).value,
      email: (document.getElementById("email") as HTMLInputElement).value,
      agency: (document.getElementById("agency") as HTMLInputElement).value,
      brands: (document.getElementById("brands") as HTMLSelectElement).value,
      message: (document.getElementById("message") as HTMLTextAreaElement).value,
      source: "signup",
    };

    try {
      const res = await fetch("/api/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (!res.ok) throw new Error("Request failed");

      form.classList.add("hidden");
      successEl.classList.remove("hidden");
    } catch {
      errorEl.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = "Request Access";
    }
  });
</script>
