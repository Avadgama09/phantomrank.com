---
import Layout from "../../layouts/Layout.astro";
import CTA from "../../components/sections/CTA.astro";
import { pageMeta } from "../../utils/data";

const meta = pageMeta.resources;
---

<Layout
  title={meta.title}
  description={meta.description}
  breadcrumbs={[
    { name: "Home", href: "/" },
    { name: "Resources", href: "/resources" },
  ]}
>
  <section class="relative mx-auto max-w-4xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div
        class="reveal inline-flex items-center gap-2 px-3 py-1 text-primary text-lg font-semibold"
      >
        Resources
      </div>
      <h1
        class="reveal text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4"
      >
        What is AI visibility tracking?
      </h1>
      <p class="reveal text-xl text-muted-foreground max-w-2xl mx-auto">
        Learn how AI search engines decide what to cite, and how agencies can
        track and improve their clients' visibility across LLMs.
      </p>
    </div>

    <div class="reveal bg-card rounded-2xl border border-border p-8 sm:p-12 mb-12 text-center">
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10">
        <svg
          class="h-8 w-8 text-primary"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"
          />
        </svg>
      </div>
      <h2 class="text-2xl font-bold text-foreground mb-4">
        Content hub coming soon
      </h2>
      <p class="text-muted-foreground max-w-lg mx-auto mb-6">
        We're building a comprehensive resource library covering AI visibility
        tracking, GEO strategies, and answer engine optimisation for Indian
        marketing agencies. Articles, guides, and tools — all in one place.
      </p>
      <p class="text-sm text-muted-foreground">
        Want to be notified when we publish?
      </p>
      <a
        href="/signup"
        class="mt-4 inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-primary/80 hover:shadow-lg hover:shadow-primary/25"
      >
        Get Access & Updates
      </a>
    </div>

    <div class="reveal">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground mb-6 text-center">
        Topics we'll cover
      </h3>
      <div class="grid gap-4 sm:grid-cols-2">
        {[
          {
            title: "AI Citation Tracking",
            description: "How to monitor when AI engines cite your brand or content.",
          },
          {
            title: "AI Visibility vs Traditional SEO",
            description: "What's different about optimising for AI answers vs Google SERPs.",
          },
          {
            title: "How AI Engines Decide What to Cite",
            description: "The signals and content characteristics that influence AI citations.",
          },
          {
            title: "GEO Checklist for Agencies",
            description: "A practical checklist for Indian agencies starting with Generative Engine Optimisation.",
          },
          {
            title: "Free AI Visibility Audit",
            description: "A self-serve tool to check your brand's current AI visibility score.",
          },
          {
            title: "PhantomRank Methodology Deep Dive",
            description: "Technical details on synthetic prompting and our research-backed approach.",
          },
        ].map((topic) => (
          <div class="bg-card rounded-2xl border border-border p-6 opacity-75">
            <h4 class="text-sm font-semibold text-foreground mb-1">
              {topic.title}
            </h4>
            <p class="text-sm text-muted-foreground">{topic.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</Layout>
