---
import Layout from "../layouts/Layout.astro";
import { pageMeta } from "../utils/data";

const meta = pageMeta.privacy;
const lastUpdated = "6 March 2026";
---

<Layout
  title={meta.title}
  description={meta.description}
  breadcrumbs={[
    { name: "Home", href: "/" },
    { name: "Privacy Policy", href: "/privacy" },
  ]}
>
  <article class="relative mx-auto max-w-3xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="mb-12">
      <h1
        class="reveal text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4"
      >
        Privacy Policy
      </h1>
      <p class="reveal text-sm text-muted-foreground">
        Last updated: {lastUpdated}
      </p>
    </div>

    <div class="space-y-8">
      <section class="reveal">
        <h2 class="text-xl font-semibold text-foreground mb-3">
          1. Introduction
        </h2>
        <p class="text-muted-foreground">
          PhantomRank ("we," "us," or "our") respects your privacy. This
          Privacy Policy explains how we collect, use, store, and protect your
          information when you use our AI visibility tracking platform and
          website at phantomrank.com.
        </p>
      </section>

      <section class="reveal">
        <h2 class="text-xl font-semibold text-foreground mb-3">
          2. Information We Collect
        </h2>
        <p class="text-muted-foreground mb-3">
          We collect the following types of information:
        </p>
        <div class="space-y-4">
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="text-sm font-semibold text-foreground mb-2">
              Account Information
            </h3>
            <p class="text-sm text-muted-foreground">
              Name, email address, agency or company name, and number of brands
              managed — provided when you create an account.
            </p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="text-sm font-semibold text-foreground mb-2">
              Brand Data
            </h3>
            <p class="text-sm text-muted-foreground">
              Brand names, competitor names, and industry categories you submit
              for AI visibility tracking. We use this data solely to perform
              scans on your behalf.
            </p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="text-sm font-semibold text-foreground mb-2">
              Usage Data
            </h3>
            <p class="text-sm text-muted-foreground">
              Pages visited, features used, scan history, and interaction
              patterns within the platform — collected automatically to
              improve the Service.
            </p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="text-sm font-semibold text-foreground mb-2">
              Technical Data
            </h3>
            <p class="text-sm text-muted-foreground">
              IP address, browser type, device information, and cookies —
              collected automatically when you visit our website.
            </p>
          </div>
        </div>
      </section>

      <section class="reveal">
        <h2 class="text-xl font-semibold text-foreground mb-3">
          3. How We Use Your Information
        </h2>
        <ul class="space-y-2 text-muted-foreground">
          {[
            "To provide, maintain, and improve the PhantomRank platform",
            "To perform AI visibility scans for the brands you submit",
            "To send you scan reports, alerts, and product updates",
            "To process payments and manage your subscription",
            "To respond to support requests and communicate with you",
            "To analyse usage patterns and improve user experience",
            "To comply with legal obligations",
          ].map((item) => (
            <li class="flex items-start gap-2">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-muted-foreground"></span>
              {item}
            </li>
          ))}
        </ul>
      </section>

      <section class="reveal">
        <h2 class="text-xl font-semibold text-foreground mb-3">
          4. Data Sharing
        </h2>
        <p class="text-muted-foreground mb-3">
          We do not sell your personal information. We may share data with:
        </p>
        <ul class="space-y-2 text-muted-foreground">
          {[
            "Service providers — hosting, analytics, and payment processing partners who assist in operating the platform",
            "Legal authorities — when required by law or to protect our rights",
            "Business transfers — in connection with a merger, acquisition, or sale of assets",
          ].map((item) => (
            <li class="flex items-start gap-2">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-muted-foreground"></span>
              {item}
            </li>
          ))}
        </ul>
      </section>

      <section class="reveal">
        <h2 class="text-xl font-semibold text-foreground mb-3">
          5. Data Storage and Security
        </h2>
        <p class="text-muted-foreground">
          Your data is stored on secure cloud infrastructure. We use
          encryption in transit (TLS) and at rest to protect your information.
          Access to personal data is restricted to authorised personnel only.
          While we implement industry-standard security measures, no method
          of transmission over the internet is 100% secure.
        </p>
      </section>

      <section class="reveal">
        <h2 class="text-xl font-semibold text-foreground mb-3">
          6. Data Retention
        </h2>
        <p class="text-muted-foreground">
          We retain your account information for as long as your account is
          active. Scan data and visibility reports are retained for the
          duration of your subscription plus 90 days. You may request
          deletion of your data at any time by contacting us.
        </p>
      </section>

      <section class="reveal">
        <h2 class="text-xl font-semibold text-foreground mb-3">
          7. Cookies
        </h2>
        <p class="text-muted-foreground">
          We use essential cookies to maintain your session and preferences
          (such as theme selection). We use analytics cookies (Vercel
          Analytics) to understand how visitors use our website. You can
          disable cookies in your browser settings, but some features may
          not function correctly.
        </p>
      </section>

      <section class="reveal">
        <h2 class="text-xl font-semibold text-foreground mb-3">
          8. Your Rights
        </h2>
        <p class="text-muted-foreground mb-3">
          You have the right to:
        </p>
        <ul class="space-y-2 text-muted-foreground">
          {[
            "Access the personal data we hold about you",
            "Correct inaccurate or incomplete data",
            "Request deletion of your personal data",
            "Export your data in a portable format",
            "Withdraw consent for marketing communications at any time",
          ].map((item) => (
            <li class="flex items-start gap-2">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-muted-foreground"></span>
              {item}
            </li>
          ))}
        </ul>
      </section>

      <section class="reveal">
        <h2 class="text-xl font-semibold text-foreground mb-3">
          9. Third-Party Services
        </h2>
        <p class="text-muted-foreground">
          PhantomRank integrates with third-party AI platforms (ChatGPT,
          Perplexity, Gemini, Claude, Grok, Copilot) to perform visibility
          scans. We query these platforms programmatically on your behalf.
          We do not share your personal information with these platforms —
          only brand and industry data necessary to execute scans.
        </p>
      </section>

      <section class="reveal">
        <h2 class="text-xl font-semibold text-foreground mb-3">
          10. Children's Privacy
        </h2>
        <p class="text-muted-foreground">
          PhantomRank is a business tool not directed at individuals under
          18 years of age. We do not knowingly collect information from
          children.
        </p>
      </section>

      <section class="reveal">
        <h2 class="text-xl font-semibold text-foreground mb-3">
          11. Changes to This Policy
        </h2>
        <p class="text-muted-foreground">
          We may update this Privacy Policy from time to time. We will notify
          you of material changes via email or through the Service. The
          "Last updated" date at the top reflects the most recent revision.
        </p>
      </section>

      <section class="reveal">
        <h2 class="text-xl font-semibold text-foreground mb-3">
          12. Contact
        </h2>
        <p class="text-muted-foreground">
          For questions about this Privacy Policy or to exercise your data
          rights, contact us at
          <a
            href="mailto:privacy@phantomrank.com"
            class="text-primary hover:text-primary/80"
          >
            privacy@phantomrank.com
          </a>.
        </p>
      </section>
    </div>
  </article>
</Layout>
