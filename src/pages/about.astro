---
import Layout from "../layouts/Layout.astro";
import { pageMeta } from "../utils/data";

const meta = pageMeta.about;
---

<Layout
  title={meta.title}
  description={meta.description}
  breadcrumbs={[
    { name: "Home", href: "/" },
    { name: "About Us", href: "/about" },
  ]}
>
  <section class="mx-auto max-w-7xl px-4 py-32 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl text-foreground">
      About PhantomRank
    </h1>
    <p class="mt-6 text-lg text-muted-foreground max-w-2xl mx-auto">
      {meta.description}
    </p>
    <p class="mt-4 text-muted-foreground max-w-2xl mx-auto">
      Full about page content coming soon.
    </p>
  </section>
</Layout>
