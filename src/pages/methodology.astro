---
import Layout from "../layouts/Layout.astro";
import CTA from "../components/sections/CTA.astro";
import { pageMeta } from "../utils/data";

const meta = pageMeta.methodology;
---

<Layout
  title={meta.title}
  description={meta.description}
  breadcrumbs={[
    { name: "Home", href: "/" },
    { name: "Methodology", href: "/methodology" },
  ]}
>
  <article class="relative mx-auto max-w-4xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div
        class="reveal inline-flex items-center gap-2 px-3 py-1 text-primary text-lg font-semibold"
      >
        Methodology
      </div>
      <h1
        class="reveal text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4"
      >
        How PhantomRank measures AI visibility
      </h1>
      <p class="reveal text-xl text-muted-foreground max-w-2xl mx-auto">
        A transparent, research-backed approach to tracking how brands appear
        inside AI-generated answers.
      </p>
    </div>

    {/* ── Synthetic Prompting ── */}
    <section class="reveal mb-12">
      <h2 class="text-2xl font-bold tracking-tight text-foreground mb-4">
        Synthetic prompting
      </h2>
      <div class="bg-card rounded-2xl border border-border p-8">
        <p class="text-muted-foreground mb-4">
          PhantomRank programmatically queries AI engines with buyer-intent
          prompts — the same kinds of questions your clients' customers are
          asking. Instead of waiting for real users to report what they see, we
          simulate thousands of queries across industries and categories to
          map exactly when and where a brand appears.
        </p>
        <p class="text-muted-foreground">
          This approach gives agencies a repeatable, measurable view of AI
          visibility — not anecdotal screenshots, but structured data you can
          track over time.
        </p>
      </div>
    </section>

    {/* ── Multi-Engine Scanning ── */}
    <section class="reveal mb-12">
      <h2 class="text-2xl font-bold tracking-tight text-foreground mb-4">
        Multi-engine scanning
      </h2>
      <div class="bg-card rounded-2xl border border-border p-8">
        <p class="text-muted-foreground mb-6">
          Every AI engine generates answers differently. A brand might be cited
          by Perplexity but completely absent from Gemini. PhantomRank scans
          all six major platforms so you see the full picture.
        </p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {[
            { name: "ChatGPT", maker: "OpenAI" },
            { name: "Perplexity", maker: "Perplexity AI" },
            { name: "Gemini", maker: "Google" },
            { name: "Claude", maker: "Anthropic" },
            { name: "Grok", maker: "xAI" },
            { name: "Copilot", maker: "Microsoft" },
          ].map((engine) => (
            <div class="rounded-xl border border-border bg-background p-4 text-center">
              <p class="font-semibold text-foreground">{engine.name}</p>
              <p class="text-xs text-muted-foreground">{engine.maker}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Three Core Metrics ── */}
    <section class="reveal mb-12">
      <h2 class="text-2xl font-bold tracking-tight text-foreground mb-4">
        The three core metrics
      </h2>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="bg-card rounded-2xl border border-border p-8">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/10">
            <svg class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 011.037-.443 48.282 48.282 0 005.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-2">
            Brand Mention Rate
          </h3>
          <p class="text-muted-foreground">
            How often your brand is named in AI-generated answers for relevant
            queries. Expressed as a percentage of total scanned prompts.
          </p>
        </div>

        <div class="bg-card rounded-2xl border border-border p-8">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-purple-500/10">
            <svg class="h-6 w-6 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.822a4.5 4.5 0 00-1.242-7.244l4.5-4.5a4.5 4.5 0 016.364 6.364l-1.757 1.757" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-2">
            Citation Frequency
          </h3>
          <p class="text-muted-foreground">
            How often your content or website is linked or referenced as a
            source in AI answers. Tracks whether AI engines trust your content
            enough to cite it.
          </p>
        </div>

        <div class="bg-card rounded-2xl border border-border p-8">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-pink-500/10">
            <svg class="h-6 w-6 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-2">
            Share of Voice
          </h3>
          <p class="text-muted-foreground">
            Your brand's visibility compared to competitors in the same
            category. Shows who AI engines recommend most — and where you
            rank in that mix.
          </p>
        </div>
      </div>
    </section>

    {/* ── Research Foundation ── */}
    <section class="reveal mb-12">
      <h2 class="text-2xl font-bold tracking-tight text-foreground mb-4">
        Research foundation
      </h2>
      <div class="bg-card rounded-2xl border border-border p-8">
        <p class="text-muted-foreground mb-4">
          PhantomRank's methodology is grounded in the Princeton GEO study
          (published at KDD 2024), the first large-scale academic research
          into Generative Engine Optimisation. The study — conducted by
          researchers at Princeton University and IIT Delhi — analysed what
          content characteristics influence whether AI engines cite a source.
        </p>
        <p class="text-muted-foreground">
          We apply these findings to structure our scanning prompts, evaluate
          citation patterns, and provide recommendations that are backed by
          peer-reviewed research — not guesswork.
        </p>
      </div>
    </section>

    {/* ── What PhantomRank Does NOT Do ── */}
    <section class="reveal mb-12">
      <h2 class="text-2xl font-bold tracking-tight text-foreground mb-4">
        What PhantomRank does not do
      </h2>
      <div class="bg-card rounded-2xl border border-border p-8">
        <ul class="space-y-4">
          {[
            "We do not guarantee AI rankings or placements. No one can.",
            "We do not manipulate AI outputs or inject content into AI engines.",
            "We do not scrape private or gated AI conversations.",
            "We are a measurement and tracking tool — we give you the data to make informed decisions.",
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-red-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6 18L18 6M6 6l12 12"
                />
              </svg>
              <span class="text-muted-foreground">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </article>

  <CTA />
</Layout>
