---
import Layout from "../layouts/Layout.astro";
import CTA from "../components/sections/CTA.astro";
import { pageMeta } from "../utils/data";

const meta = pageMeta.dashboard;

const demoUrl = "https://phantom-rankapp-3l54.vercel.app";
const demoCredentials = {
  email: "demo@phantomrank.com",
  password: "demo1234",
};
---

<Layout
  title={meta.title}
  description={meta.description}
  breadcrumbs={[
    { name: "Home", href: "/" },
    { name: "Dashboard", href: "/dashboard" },
  ]}
>
  <section class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div
        class="reveal inline-flex items-center gap-2 px-3 py-1 text-primary text-lg font-semibold"
      >
        Live Demo
      </div>
      <h1
        class="reveal text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4"
      >
        Explore the PhantomRank dashboard
      </h1>
      <p class="reveal text-xl text-muted-foreground max-w-2xl mx-auto">
        Click through a fully working dashboard with sample data. No signup
        required — see exactly what you'll get.
      </p>
    </div>

    <div class="reveal mb-8 mx-auto max-w-md">
      <div class="bg-card rounded-2xl border border-border p-6 text-center">
        <p class="text-sm font-medium text-foreground mb-3">Demo Credentials</p>
        <div class="space-y-2 text-sm text-muted-foreground">
          <p>
            Email: <code class="rounded bg-foreground/10 px-2 py-0.5 text-foreground">{demoCredentials.email}</code>
          </p>
          <p>
            Password: <code class="rounded bg-foreground/10 px-2 py-0.5 text-foreground">{demoCredentials.password}</code>
          </p>
        </div>
        <a
          href={demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-primary/80 hover:shadow-lg hover:shadow-primary/25"
        >
          Open Live Demo
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
            />
          </svg>
        </a>
      </div>
    </div>

    <div class="reveal rounded-2xl border border-border overflow-hidden bg-card">
      <iframe
        src={demoUrl}
        title="PhantomRank Dashboard Demo"
        class="w-full h-150 sm:h-175 lg:h-200"
        loading="lazy"
      />
    </div>
  </section>

  <CTA />
</Layout>
