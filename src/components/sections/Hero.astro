---
// Hero copy is inline — only used once on the homepage
---

<section class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
  <div class="text-center">
    <div
      class="reveal inline-flex items-center gap-2 rounded-full border border-border bg-card px-4 py-1.5 text-sm text-muted-foreground mb-8"
    >
      <span class="relative flex h-2 w-2">
        <span
          class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"
        ></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"
        ></span>
      </span>
      Now tracking 6 AI engines
    </div>

    <h1
      class="reveal text-4xl font-bold tracking-tight sm:text-6xl lg:text-7xl text-foreground"
    >
      Your brand is invisible in
      <span
        class="bg-linear-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent"
      >
        AI search
      </span>
    </h1>

    <p class="reveal mt-6 text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto">
      ChatGPT, Perplexity, Gemini, and Claude are answering your clients'
      buyer questions — without mentioning their brand. PhantomRank shows you
      exactly where you stand.
    </p>

    <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/signup"
        class="rounded-full bg-primary px-8 py-3.5 text-sm font-semibold text-white transition-all hover:bg-primary/80 hover:shadow-lg hover:shadow-primary/25"
      >
        Get Access — It's Free
      </a>
      <a
        href="/dashboard"
        class="rounded-full bg-foreground/10 px-8 py-3.5 text-sm font-semibold text-foreground transition-all hover:bg-foreground/20"
      >
        Try the Live Demo
      </a>
    </div>

    <p class="reveal mt-4 text-xs text-muted-foreground">
      Free plan available · No credit card required
    </p>
  </div>
</section>
