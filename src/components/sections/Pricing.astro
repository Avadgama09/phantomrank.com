---
import { plans } from "../../utils/data";

interface Props {
  variant?: "preview" | "full";
}

const { variant = "preview" } = Astro.props;

const isPreview = variant === "preview";
const displayPlans = isPreview ? plans.slice(0, 3) : plans;
---

<section class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
  <div class="text-center mb-16">
    <div
      class="reveal inline-flex items-center gap-2 px-3 py-1 text-primary text-lg font-semibold"
    >
      Pricing
    </div>
    <h2
      class="reveal text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4"
    >
      {isPreview
        ? "Simple, transparent pricing"
        : "Plans for every agency size"}
    </h2>
    <p class="reveal text-xl text-muted-foreground max-w-2xl mx-auto">
      {isPreview
        ? "Start free. Upgrade as your client portfolio grows."
        : "All plans include access to all AI engines. No hidden fees. Cancel anytime."}
    </p>
  </div>

  <div
    class:list={[
      "grid gap-6",
      isPreview ? "md:grid-cols-3" : "md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5",
    ]}
  >
    {displayPlans.map((plan) => (
      <div
        class:list={[
          "reveal relative flex flex-col rounded-2xl border p-8 shadow-sm transition-all",
          plan.isPopular
            ? "border-primary bg-card ring-2 ring-primary/20"
            : "border-border bg-card hover:border-primary/50",
        ]}
      >
        {plan.isPopular && (
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="inline-flex items-center rounded-full bg-primary px-3 py-1 text-xs font-semibold text-white">
              Most Popular
            </span>
          </div>
        )}

        <div class="mb-6">
          <h3 class="text-lg font-semibold text-foreground">{plan.name}</h3>
          <p class="text-sm text-muted-foreground mt-1">{plan.description}</p>
        </div>

        <div class="mb-6">
          <span class="text-4xl font-bold tracking-tight text-foreground">
            {plan.price}
          </span>
          <span class="text-sm text-muted-foreground ml-1">
            /{plan.period === "forever" ? "free forever" : plan.period.replace("per ", "")}
          </span>
        </div>

        <ul class="mb-8 grow space-y-3">
          {plan.features.map((feature) => (
            <li class="flex items-start gap-2">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-green-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.5 12.75l6 6 9-13.5"
                />
              </svg>
              <span class="text-sm text-muted-foreground">{feature}</span>
            </li>
          ))}
        </ul>

        <a
          href={plan.cta.href}
          class:list={[
            "mt-auto block w-full rounded-full py-3 text-center text-sm font-semibold transition-all",
            plan.cta.variant === "primary"
              ? "bg-primary text-white hover:bg-primary/80 hover:shadow-lg hover:shadow-primary/25"
              : "bg-foreground/10 text-foreground hover:bg-foreground/20",
          ]}
        >
          {plan.cta.text}
        </a>
      </div>
    ))}
  </div>

  {isPreview && (
    <div class="reveal text-center mt-12">
      <p class="text-muted-foreground mb-4">
        Need more? We have Agency and Enterprise plans for larger teams.
      </p>
      <a
        href="/pricing"
        class="inline-flex items-center gap-2 text-sm font-medium text-primary transition-colors hover:text-primary/80"
      >
        View all plans
        <svg
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
          />
        </svg>
      </a>
    </div>
  )}
</section>
