---
import type { Feature } from "../../types/types";

interface Props {
  feature: Feature;
  problem: string;
  howItWorks: string[];
  whoItsFor: string[];
}

const { feature, problem, howItWorks, whoItsFor } = Astro.props;

const isLive = feature.status === "live";
---

<article class="relative mx-auto max-w-4xl px-4 py-24 sm:px-6 lg:px-8">
  {/* ── Status Banner ── */}
  {!isLive && (
    <div class="reveal mb-8 rounded-xl border border-amber-500/20 bg-amber-500/5 p-4 text-center">
      <p class="text-sm text-amber-400 font-medium">
        This feature is currently in development. Get notified when it launches.
      </p>
    </div>
  )}

  {/* ── Header ── */}
  <div class="reveal mb-12">
    <div class="flex items-center gap-3 mb-4">
      <span
        class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-medium ${
          isLive
            ? "bg-green-500/10 text-green-400"
            : "bg-amber-500/10 text-amber-400"
        }`}
      >
        {isLive ? "Available Now" : "Coming Soon"}
      </span>
      <span class="text-sm text-muted-foreground">
        {feature.category}
      </span>
    </div>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4">
      {feature.name}
    </h1>
    <p class="text-xl text-muted-foreground">
      {feature.oneLiner}
    </p>
  </div>

  {/* ── The Problem It Solves ── */}
  <section class="reveal mb-12">
    <h2 class="text-xl font-semibold text-foreground mb-4">
      The problem
    </h2>
    <div class="bg-card rounded-2xl border border-border p-8">
      <p class="text-muted-foreground">{problem}</p>
    </div>
  </section>

  {/* ── How It Works ── */}
  <section class="reveal mb-12">
    <h2 class="text-xl font-semibold text-foreground mb-4">
      How it works
    </h2>
    <div class="bg-card rounded-2xl border border-border p-8">
      <ul class="space-y-4">
        {howItWorks.map((step, index) => (
          <li class="flex items-start gap-4">
            <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-semibold text-primary">
              {index + 1}
            </span>
            <p class="text-muted-foreground pt-0.5">{step}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ── Who It's For ── */}
  <section class="reveal mb-12">
    <h2 class="text-xl font-semibold text-foreground mb-4">
      Who it's for
    </h2>
    <div class="bg-card rounded-2xl border border-border p-8">
      <ul class="space-y-3">
        {whoItsFor.map((audience) => (
          <li class="flex items-start gap-3">
            <svg
              class="mt-0.5 h-5 w-5 shrink-0 text-green-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4.5 12.75l6 6 9-13.5"
              />
            </svg>
            <span class="text-muted-foreground">{audience}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ── CTA ── */}
  <div class="reveal text-center">
    {isLive ? (
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/dashboard"
          class="rounded-full bg-primary px-8 py-3.5 text-sm font-semibold text-white transition-all hover:bg-primary/80 hover:shadow-lg hover:shadow-primary/25"
        >
          Try It in the Dashboard
        </a>
        <a
          href="/signup"
          class="rounded-full bg-foreground/10 px-8 py-3.5 text-sm font-semibold text-foreground transition-all hover:bg-foreground/20"
        >
          Get Access
        </a>
      </div>
    ) : (
      <div class="flex flex-col items-center gap-4">
        <a
          href="/signup"
          class="rounded-full bg-primary px-8 py-3.5 text-sm font-semibold text-white transition-all hover:bg-primary/80 hover:shadow-lg hover:shadow-primary/25"
        >
          Get Notified When This Launches
        </a>
        <a
          href="/features"
          class="inline-flex items-center gap-2 text-sm font-medium text-primary transition-colors hover:text-primary/80"
        >
          View all features
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
            />
          </svg>
        </a>
      </div>
    )}
  </div>
</article>
