---
import { stats } from "../../utils/data";
---

<section class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
  <div class="text-center mb-16">
    <div
      class="reveal inline-flex items-center gap-2 px-3 py-1 text-primary text-lg font-semibold"
    >
      Built for Scale
    </div>
    <h2
      class="reveal text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4"
    >
      PhantomRank by the numbers
    </h2>
  </div>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {stats.map((stat) => (
      <div
        class="reveal bg-card p-8 rounded-2xl border border-border shadow-sm text-center"
      >
        <p class="text-4xl font-bold tracking-tight text-foreground mb-2">
          {stat.value}
        </p>
        <p class="text-sm text-muted-foreground">{stat.label}</p>
      </div>
    ))}
  </div>

  <div class="reveal mt-16 rounded-2xl border border-border bg-card p-8 sm:p-12">
    <div class="grid gap-8 md:grid-cols-2 items-center">
      <div>
        <h3 class="text-2xl font-bold tracking-tight text-foreground mb-4">
          Grounded in research
        </h3>
        <p class="text-muted-foreground mb-4">
          PhantomRank's methodology is built on the Princeton GEO study
          (KDD 2024) — the first large-scale academic research into what
          influences AI citation rates. We don't guess at what works. We
          measure what the research proves.
        </p>
        <a
          href="/methodology"
          class="inline-flex items-center gap-2 text-sm font-medium text-primary transition-colors hover:text-primary/80"
        >
          Read our methodology
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
            />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="rounded-xl bg-blue-500/10 p-6 text-center">
          <p class="text-2xl font-bold text-blue-400">6</p>
          <p class="text-xs text-muted-foreground mt-1">AI Platforms</p>
        </div>
        <div class="rounded-xl bg-purple-500/10 p-6 text-center">
          <p class="text-2xl font-bold text-purple-400">3</p>
          <p class="text-xs text-muted-foreground mt-1">Core Metrics</p>
        </div>
        <div class="rounded-xl bg-pink-500/10 p-6 text-center">
          <p class="text-2xl font-bold text-pink-400">KDD</p>
          <p class="text-xs text-muted-foreground mt-1">2024 Research</p>
        </div>
        <div class="rounded-xl bg-green-500/10 p-6 text-center">
          <p class="text-2xl font-bold text-green-400">100%</p>
          <p class="text-xs text-muted-foreground mt-1">Measurement Only</p>
        </div>
      </div>
    </div>
  </div>
</section>
