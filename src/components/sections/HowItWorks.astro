---
// HowItWorks copy is inline — only used once on the homepage
---

<section class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
  <div class="text-center mb-16">
    <div
      class="reveal inline-flex items-center gap-2 px-3 py-1 text-primary text-lg font-semibold"
    >
      How It Works
    </div>
    <h2
      class="reveal text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4"
    >
      Three steps to AI visibility
    </h2>
    <p class="reveal text-xl text-muted-foreground max-w-2xl mx-auto">
      Start tracking in minutes. No code, no complex setup.
    </p>
  </div>

  <div class="relative grid gap-8 md:grid-cols-3">
    <!-- Connector line (desktop only) -->
    <div
      class="absolute top-16 left-[16.67%] right-[16.67%] hidden md:block h-px bg-border"
    >
    </div>

    <!-- Step 1 -->
    <div class="reveal text-center">
      <div class="relative mx-auto mb-6">
        <div
          class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 border-2 border-primary text-primary text-xl font-bold"
        >
          1
        </div>
      </div>
      <h3 class="text-lg font-semibold text-foreground mb-2">
        Add your brands
      </h3>
      <p class="text-muted-foreground max-w-xs mx-auto">
        Enter your client's brand name and industry. Add competitors you want
        to benchmark against. Takes under a minute.
      </p>
    </div>

    <!-- Step 2 -->
    <div class="reveal text-center">
      <div class="relative mx-auto mb-6">
        <div
          class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 border-2 border-primary text-primary text-xl font-bold"
        >
          2
        </div>
      </div>
      <h3 class="text-lg font-semibold text-foreground mb-2">
        We scan AI engines
      </h3>
      <p class="text-muted-foreground max-w-xs mx-auto">
        PhantomRank runs buyer-intent queries across ChatGPT, Perplexity,
        Gemini, Claude, Grok, and Copilot — using synthetic prompting to map
        where your brand appears.
      </p>
    </div>

    <!-- Step 3 -->
    <div class="reveal text-center">
      <div class="relative mx-auto mb-6">
        <div
          class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 border-2 border-primary text-primary text-xl font-bold"
        >
          3
        </div>
      </div>
      <h3 class="text-lg font-semibold text-foreground mb-2">
        See your visibility data
      </h3>
      <p class="text-muted-foreground max-w-xs mx-auto">
        Get a dashboard with brand mention rates, citation frequency, and share
        of voice — plus competitor comparisons and weekly trend reports.
      </p>
    </div>
  </div>

  <div class="reveal text-center mt-12">
    <a
      href="/methodology"
      class="inline-flex items-center gap-2 text-sm font-medium text-primary transition-colors hover:text-primary/80"
    >
      Learn how our methodology works
      <svg
        class="h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
      </svg>
    </a>
  </div>
</section>
