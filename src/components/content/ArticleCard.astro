---
// src/components/content/ArticleCard.astro
interface Props {
  title: string;
  href: string;
  hubTitle: string;
  clusterTitle: string;
  readTime?: string;
}

const { title, href, hubTitle, clusterTitle, readTime } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col rounded-xl border border-border bg-background/60 p-5 transition-all hover:border-primary/40 hover:shadow-md hover:shadow-primary/5"
>
  <div class="mb-3 flex items-center gap-2">
    <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
      {hubTitle}
    </span>
    <span class="text-xs text-muted-foreground">
      {clusterTitle}
    </span>
  </div>

  <h3 class="text-base font-semibold text-foreground transition-colors group-hover:text-primary">
    {title}
  </h3>

  {readTime && (
    <span class="mt-3 text-xs text-muted-foreground">
      {readTime}
    </span>
  )}
</a>